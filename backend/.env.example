# CollabBridge Backend – Environment Variables Template
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# -------------------------------------------------------

# --- Gemini AI Configuration ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# --- Database ---
DATABASE_URL=sqlite:///./collabbridge.db

# --- Security (generate a strong random value!) ---
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_strong_random_secret_key_here
PASSWORD_SALT=change_me_generate_a_unique_random_salt_here

# --- CORS (comma-separated list of allowed frontend origins) ---
# Development: http://localhost:5173,http://localhost:3000
# Production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
# Maximum requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60

# --- Google OAuth (optional, for Google Sign-In) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
